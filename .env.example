# Copy this file to .env and fill in real values.
# Never commit .env to version control.

# Base URL of the Oregon API (trailing /api is stripped automatically)
OREGON_BASE_URL=https://your-api-host.example.com

# Login credentials used to obtain a fresh token when OREGON_AUTH_TOKEN is missing or expired
OREGON_AUTH_EMAIL=your_email@example.com
OREGON_AUTH_PASSWORD=your_password

# Bearer token (auto-populated after first successful login; leave blank to force re-login)
OREGON_AUTH_TOKEN=

# Dynamic IDs persisted between test runs (auto-populated by the test suite)
REPORT_ID=
VEHICLE_ID=
