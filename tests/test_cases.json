{
  "test_scenarios": {
    "authentication": {
      "description": "User authentication: login and registration validation",
      "test_cases": {
        "positive_login": {
          "description": "Valid login using credentials from environment",
          "endpoint": "/api/auth/login",
          "method": "POST",
          "content_type": "form",
          "auth_required": false,
          "requires_env": ["OREGON_AUTH_EMAIL", "OREGON_AUTH_PASSWORD"],
          "payload": {
            "email": "{OREGON_AUTH_EMAIL}",
            "password": "{OREGON_AUTH_PASSWORD}",
            "remember_me": "0"
          },
          "expected_status": [200, 201],
          "expected_response_keys": ["success", "data", "token", "access_token"],
          "schema": "login",
          "schema_validation": true
        },
        "negative_login_invalid_credentials": {
          "description": "Login with wrong email and password",
          "endpoint": "/api/auth/login",
          "method": "POST",
          "content_type": "form",
          "auth_required": false,
          "requires_env": [],
          "payload": {
            "email": "invalid@example.com",
            "password": "wrong-password",
            "remember_me": "0"
          },
          "expected_status": [400, 401, 422],
          "expected_response_keys": ["errors", "message"],
          "schema": null,
          "schema_validation": false
        },
        "negative_login_empty_credentials": {
          "description": "Login with empty email and password fields",
          "endpoint": "/api/auth/login",
          "method": "POST",
          "content_type": "form",
          "auth_required": false,
          "requires_env": [],
          "payload": {
            "email": "",
            "password": "",
            "remember_me": "0"
          },
          "expected_status": [400, 401, 422],
          "expected_response_keys": ["errors", "message"],
          "schema": null,
          "schema_validation": false
        },
        "negative_login_missing_fields": {
          "description": "Login request missing the password field",
          "endpoint": "/api/auth/login",
          "method": "POST",
          "content_type": "form",
          "auth_required": false,
          "requires_env": [],
          "payload": {
            "email": "test@example.com"
          },
          "expected_status": [400, 422],
          "expected_response_keys": ["errors", "message"],
          "schema": null,
          "schema_validation": false
        },
        "negative_login_sql_injection": {
          "description": "Login attempt with SQL injection payload",
          "endpoint": "/api/auth/login",
          "method": "POST",
          "content_type": "form",
          "auth_required": false,
          "requires_env": [],
          "payload": {
            "email": "admin' OR '1'='1",
            "password": "' OR '1'='1",
            "remember_me": "0"
          },
          "expected_status": [400, 401, 422],
          "expected_response_keys": ["errors", "message"],
          "schema": null,
          "schema_validation": false
        },
        "negative_register_invalid_data": {
          "description": "Registration with all invalid field values",
          "endpoint": "/api/auth/register",
          "method": "POST",
          "content_type": "form",
          "auth_required": false,
          "requires_env": [],
          "payload": {
            "full_name": "",
            "usdot": "invalid",
            "email": "invalid-email",
            "cdd_account": "",
            "phone": "invalid-phone",
            "password": "123",
            "password_confirmation": "456"
          },
          "expected_status": [400, 422],
          "expected_response_keys": ["errors", "message"],
          "schema": null,
          "schema_validation": false
        },
        "negative_register_password_mismatch": {
          "description": "Registration where password and confirmation do not match",
          "endpoint": "/api/auth/register",
          "method": "POST",
          "content_type": "form",
          "auth_required": false,
          "requires_env": [],
          "payload": {
            "full_name": "Test User",
            "usdot": "1234567",
            "email": "test@example.com",
            "cdd_account": "TEST123",
            "phone": "(555) 123-4567",
            "password": "password123",
            "password_confirmation": "differentpassword"
          },
          "expected_status": [400, 422],
          "expected_response_keys": ["errors", "message"],
          "schema": null,
          "schema_validation": false
        }
      }
    },
